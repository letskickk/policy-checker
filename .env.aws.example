# AWS 배포용 .env 예시
# 1. 이 파일을 .env로 복사: cp .env.aws.example .env
# 2. OPENAI_API_KEY만 본인 키로 수정
# 3. 로컬 .env와 따로 관리할 필요 없음 — 이 내용이 로컬과 동일하게 동작

OPENAI_API_KEY=sk-proj-여기에본인키

# 모델: gpt-5.2 (Responses API)
OPENAI_MODEL=gpt-5.2
CHAT_MODEL=gpt-5.2

# Vector Store 사용 (FAISS 대신)
USE_OPENAI_VECTOR_STORE=1

# 첫 실행 후 로그에 나온 ID를 넣으면 재시작 시 빠름 (자동 추가됨)
# OPENAI_VECTOR_STORE_ID=vs_xxx      (정강+공약)
# OPENAI_REGIONAL_VECTOR_STORE_ID=vs_yyy  (지역별 공약, 타지역 유사성 검토용)

# S3에서 PDF 받을 때만 (공약 폴더가 비어 있으면 sync)
# PDF_S3_URI=s3://버킷명/경로/

# 공공데이터포털 인증키 (동일 키로 아래 API 모두 사용)
# - 당선인 정보: https://apis.data.go.kr/9760000/WinnerInfoInqireService2 (당 부합 점검 시 2022 당선인 이름 보강)
# - 선거공약 정보: https://apis.data.go.kr/9760000/ElecPrmsInfoInqireService
# - 지방선거 세부선거구: scripts/build_district_sub_from_api.py
# 활용신청: 당선인 https://www.data.go.kr/data/15000864 | 선거공약 https://www.data.go.kr/data/15040587
# DATA_GO_KR_API_KEY=공공데이터포털_일반인증키
